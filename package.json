{
	"name": "app-api",
	"version": "1.0.0",
	"main": "index.js",
	"scripts": {
		"dev": "NODE_ENV=development ts-node-dev --respawn --transpile-only src/server.ts",
		"dev:staging": "NODE_ENV=staging ts-node-dev --respawn --transpile-only src/server.ts",
		"dev:production": "NODE_ENV=production ts-node-dev --respawn --transpile-only src/server.ts",
		"dev:debug": "ts-node-dev --respawn --transpile-only --inspect=0.0.0.0:9229 src/server.ts",
		"build": "tsc",
		"start": "node dist/server.js",
		"start:debug": "node --inspect=0.0.0.0:9229 dist/server.js",
		"type-check": "tsc --noEmit",
		"lint": "eslint . --max-warnings=0",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write \"src/**/*.{ts,js,json}\"",
		"format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage",
		"test:unit": "jest --testPathPattern=unit",
		"test:integration": "jest --testPathPattern=integration",
		"docker:up": "docker compose up -d mongodb redis",
		"docker:down": "docker compose down",
		"docker:logs": "docker compose logs -f",
		"seed:catalog": "ts-node -r tsconfig-paths/register src/scripts/seed-document-catalog.ts"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"description": "",
	"devDependencies": {
		"@faker-js/faker": "^10.3.0",
		"@types/bcrypt": "^6.0.0",
		"@types/cookie-parser": "^1.4.10",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/jest": "^30.0.0",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/multer": "^2.1.0",
		"@types/node": "^25.4.0",
		"@types/node-cron": "^3.0.11",
		"@types/swagger-ui-express": "^4.1.8",
		"@typescript-eslint/eslint-plugin": "^8.57.0",
		"@typescript-eslint/parser": "^8.57.0",
		"eslint": "^9.39.4",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import": "^2.32.0",
		"jest": "^30.3.0",
		"mongodb-memory-server": "^11.0.1",
		"pino-pretty": "^13.1.3",
		"ts-jest": "^29.4.6",
		"ts-node-dev": "^2.0.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1021.0",
		"@aws-sdk/s3-request-presigner": "^3.1021.0",
		"axios": "^1.13.6",
		"bcrypt": "^6.0.0",
		"bullmq": "^5.76.1",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.6",
		"dotenv": "^17.3.1",
		"express": "^5.2.1",
		"express-rate-limit": "^8.3.1",
		"helmet": "^8.1.0",
		"ioredis": "^5.10.0",
		"jsonwebtoken": "^9.0.3",
		"mongodb": "^7.1.0",
		"multer": "^2.1.1",
		"node-cron": "^4.2.1",
		"openid-client": "^5.7.1",
		"pino": "^10.3.1",
		"pino-http": "^11.0.0",
		"rate-limit-redis": "^4.3.1",
		"swagger-ui-express": "^5.0.1",
		"zod": "^4.3.6"
	}
}
